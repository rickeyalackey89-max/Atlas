# =========================
# Exclude only true ephemeral outputs
# =========================
data/output/debug/
data/output/runs/*/debug/

# Large intermediate zips — not needed in git
data/bundles/
archives/bundles/

# Large binary caches — exceed GitHub 100 MB limit, rebuild with build_v16_cache.py
data/model/_v16_resim_cache.pkl
data/model/_*_resim_cache.pkl

# ============================================================
# EVERYTHING BELOW IS INTENTIONALLY TRACKED
# These are costly/irreplaceable assets. DO NOT gitignore them.
# ============================================================
# data/raw/             -> PrizePicks raw JSON snapshots (needed for replay/resim)
# data/gamelogs/        -> ESPN box scores, season-long (needed for GBM features)
# data/model/           -> ALL model artifacts: ensemble, pkl, json, txt, csv
# data/telemetry/       -> corpus, live run history, eval legs
# data/archives/        -> OddsAPI cache (paid per pull), IAEL snapshots
# data/input/           -> rotowire, external priors, roster map